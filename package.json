  },
  "homepage": "https://github.com/MarceliJankowski/dev-camper#readme",
  "dependencies": {
    "express": "^4.18.1",
    "husky": "^8.0.1",
    "mongoose": "^6.4.3",
    "node-geocoder": "^4.1.0",
    "slugify": "^1.6.5",
    "validator": "^13.7.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.13",
    "@types/morgan": "^1.9.3",
    "@types/node": "^18.0.1",
    "@types/node-geocoder": "^3.24.5",
    "@types/supertest": "^2.0.12",
    "@types/validator": "^13.7.4",
    "morgan": "^1.10.0",
    "nodemon": "^2.0.18",
    "supertest": "^6.2.4",
    "ts-node": "^10.8.2",
